# Comma-separated list of public Instagram usernames to scrape
USERNAMES=natgeo,nasa

# Cron schedule (default: every 6 hours)
CRON_SCHEDULE=0 */6 * * *

# Max posts to fetch per user per scrape cycle
MAX_POSTS_PER_USER=12

# Request delay (ms) between requests to avoid rate limiting
REQUEST_DELAY_MS=3000

# Data directory for scraped output
DATA_DIR=./data

# Dashboard port
DASHBOARD_PORT=3000

# User-Agent rotation (optional, comma-separated)
# CUSTOM_USER_AGENTS=Mozilla/5.0 ...
